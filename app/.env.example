# Where the app talks to the backend. Optional — the app is fully usable offline with no backend
# (bundled catalog + on-device compute). Set this to enable catalog refresh, accounts and sync.
#
# Must end in /api (the backend serves everything under the /api global prefix).
#   - Local dev (device/emulator on your LAN): http://<your-PC-LAN-IP>:3000/api
#   - Production: https://<your-cloudflare-tunnel-host>/api
#
# EXPO_PUBLIC_* vars are inlined into the client bundle at build time (they are NOT secret).
EXPO_PUBLIC_API_URL=
