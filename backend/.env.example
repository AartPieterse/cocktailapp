# --- Backend environment ---
# Copy this file to `backend/.env` and fill in your real values.
# NEVER commit the real .env (it is gitignored).

# MongoDB Atlas connection string.
# Atlas > Database > Connect > Drivers. Include the database name (e.g. /cocktailapp).
# Also make sure your current IP is allowlisted under Atlas > Network Access.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cocktailapp?retryWrites=true&w=majority

# Port the API listens on (default 3000). The API is served under the /api prefix.
PORT=3000
