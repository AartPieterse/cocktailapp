# --- Backend environment ---
# Copy this file to `backend/.env` and fill in your real values.
# NEVER commit the real .env (it is gitignored).

# MongoDB connection string. Include the database name (e.g. /cocktailapp).
# Local dev: a Dockerised Mongo (see deploy/) with a SEPARATE db name from prod.
# Atlas: Atlas > Database > Connect > Drivers; allowlist your IP under Network Access.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cocktailapp?retryWrites=true&w=majority

# Port the API listens on (default 3000). The API is served under the /api prefix.
PORT=3000

# --- Auth / JWT (Phase 2) ---
# Two INDEPENDENT high-entropy secrets (e.g. `openssl rand -base64 48`). Access and refresh
# tokens are signed with different secrets so a refresh token can't be replayed as an access token.
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
# Token lifetimes (any `ms`/jsonwebtoken duration string). Keep the access token short.
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# --- CORS ---
# Comma-separated allowlist of the web origin(s), e.g. https://barkast.example.
# REQUIRED in production (the app refuses to boot without it); optional in dev (reflects any).
# CORS_ORIGIN=https://barkast.example

# --- Reverse proxy ---
# Number of proxy hops to trust for the real client IP (Cloudflare Tunnel = 1). Default: 1.
# TRUST_PROXY=1

# --- LAN admin dashboard (Phase 10, analytics) ---
# Basic-auth credentials for the LAN-only admin endpoints (/api/admin/metrics, /api/admin/dashboard).
# The admin routes ALSO reject any request that arrived via the Cloudflare Tunnel (CF-Connecting-IP
# present), so they stay invisible to the public internet. If either value is unset, ALL admin
# access is denied (fail-closed).
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-long-random
