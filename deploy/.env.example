# --- deploy/.env — Barkast self-host secrets ---
# Copy to deploy/.env and fill in real values. deploy/.env is gitignored; NEVER commit it.

# MongoDB root credentials (the api assembles MONGODB_URI from these).
# Use a long random password, e.g. `openssl rand -base64 24`.
MONGO_USER=barkast
MONGO_PASSWORD=change-me-long-random
MONGO_DB=barkast

# JWT signing secrets — TWO DIFFERENT high-entropy values (`openssl rand -base64 48`).
# The API refuses to boot if these are equal.
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# CORS allowlist — the web origin(s), comma-separated. REQUIRED (prod boots with NODE_ENV=production).
CORS_ORIGIN=https://barkast.example

# Cloudflare Tunnel token: Zero Trust dashboard → Networks → Tunnels → (your tunnel) → token.
TUNNEL_TOKEN=change-me

# --- Deploy (deploy/deploy.sh) ---
# GHCR image the box pulls. Must match the CI-published package (lowercase owner).
IMAGE_REPO=ghcr.io/aartpieterse/barkast-api

# --- LAN admin dashboard (analytics/metrics at /api/admin/*) ---
# Basic-auth creds. The admin routes also reject anything arriving via the tunnel, so they are
# LAN-only. Publish the API to the LAN with docker-compose.admin.yml (see deploy/README.md), then
# open http://barkast.local:8080/api/admin/dashboard on the home network.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-long-random

# --- Backups (deploy/backup.sh) ---
# age recipient PUBLIC key (encrypt-to). Keep the matching PRIVATE key OFF this box.
AGE_RECIPIENT=age1examplexxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Where encrypted dumps are written, and how many newest to keep.
BACKUP_DIR=./backups
BACKUP_KEEP=14
